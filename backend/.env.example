# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database Configuration
# MongoDB Connection String (local or Atlas)
# Local: mongodb://127.0.0.1:27017/sustainsutra
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/sustainsutra
MONGO_URI=mongodb://127.0.0.1:27017/sustainsutra
REQUIRE_DB=false

# JWT Configuration
# REQUIRED in production. Generate a strong secret with:
#   openssl rand -base64 64
# Do NOT use the placeholder below in any real deployment.
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRE=7d

# Email Configuration (Optional)
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@sustainsutra.in

# Payment Gateway (Test Mode)
# Get from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=test_secret_xxxxx

# Error Tracking (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Demo Mode (DEVELOPMENT ONLY).
# When true (and NODE_ENV is NOT production), the server starts without a
# database using in-memory mock data. Demo mode accepts ANY password for known
# emails — it must NEVER be used in production. In production a DB outage always
# fails closed (process.exit) regardless of this setting.
DEMO_MODE=false

# AI API Keys (Optional)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://api.z.ai/api/coding/paas/v4
